# ============================================================================
# UFDR Analysis Tool - Environment Configuration Template
# ============================================================================
# Copy this file to .env and populate with your actual API keys before use
# ============================================================================

# Application Settings
STREAMLIT_PORT=8501
STREAMLIT_HOST=localhost
APP_ENV=development

# Database Configuration
DATABASE_PATH=forensic_data.db

# ============================================================================
# Cloud AI API Configuration
# ============================================================================
# Primary: Google Gemini (Recommended for best performance/cost)
GEMINI_API_KEY=your_gemini_api_key_here

# Backup: OpenAI GPT-4 (Fallback if Gemini unavailable)
OPENAI_API_KEY=your_openai_api_key_here

# Alternative: Anthropic Claude (Additional fallback)
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# Alternative: OpenRouter (Recommended for testing/mix of models)
OPENROUTER_API_KEY=your_openrouter_api_key_here

# Deployment Mode (local or cloud)
DEPLOYMENT_MODE=local

# Neo4j Graph Database (optional — not required for core functionality)
# NEO4J_URI=bolt://localhost:7687
# NEO4J_USER=neo4j
# NEO4J_PASSWORD=your_neo4j_password_here

# Storage Configuration
STORAGE_PROVIDER=local
UPLOAD_DIR=uploads/ufdr
EXTRACTION_DIR=uploads/ufdr_extractions
EXPORT_DIR=exports
LOGS_DIR=logs

# Logging Configuration
LOG_LEVEL=INFO
LOG_FILE=logs/ufdr_app.log
DEBUG_MODE=false

# Feature Flags
ENABLE_AI_ANALYSIS=true
ENABLE_GRAPH_VIZ=false
ENABLE_MEDIA_PROCESSING=true
ENABLE_SEMANTIC_SEARCH=true

# Performance Configuration
WORKER_THREADS=4
BATCH_SIZE=100
USE_GPU=false